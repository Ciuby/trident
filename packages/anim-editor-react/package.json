{
  "name": "@ggez/anim-editor-react",
  "version": "0.1.0",
  "description": "React bindings and workspace components for the ggez animation editor.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config ../../scripts/tsup.package.config.mjs",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ggez/anim-editor-core": "workspace:*",
    "@ggez/anim-exporter": "workspace:*",
    "@ggez/anim-schema": "workspace:*",
    "@xyflow/react": "^12.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.25.76"
  }
}
