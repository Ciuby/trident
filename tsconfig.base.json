{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/editor/src/*"],
      "@gg-ez/dev-sync": ["packages/dev-sync/src/index.ts"],
      "@gg-ez/dev-sync/node": ["packages/dev-sync/src/node.ts"],
      "@gg-ez/shared": ["packages/shared/src/index.ts"],
      "@gg-ez/editor-core": ["packages/editor-core/src/index.ts"],
      "@gg-ez/geometry-kernel": ["packages/geometry-kernel/src/index.ts"],
      "@gg-ez/gameplay-runtime": ["packages/gameplay-runtime/src/index.ts"],
      "@gg-ez/render-pipeline": ["packages/render-pipeline/src/index.ts"],
      "@gg-ez/runtime-build": ["packages/runtime-build/src/index.ts"],
      "@gg-ez/runtime-format": ["packages/runtime-format/src/index.ts"],
      "@gg-ez/runtime-physics-rapier": ["packages/runtime-physics-rapier/src/index.ts"],
      "@gg-ez/runtime-streaming": ["packages/runtime-streaming/src/index.ts"],
      "@gg-ez/three-runtime": ["packages/three-runtime/src/index.ts"],
      "@gg-ez/tool-system": ["packages/tool-system/src/index.ts"],
      "@gg-ez/workers": ["packages/workers/src/index.ts"]
    }
  }
}
